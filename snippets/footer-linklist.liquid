<ul class="{% unless has_two_linklists %} flex flex-wrap {% endunless %} -mx-2 -my-1 text-theme-basic">
  {% for link in linklist.links %}
    <li class="break-word mx-2 my-1">
      <a
        href="{{ link.url }}"
        class="underline-offset-basic hover:underline"
      >
        {{ link.title }}
      </a>
    </li>
  {% endfor %}
</ul>

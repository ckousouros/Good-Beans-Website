<div
  class="my-6 group-first:mt-0"
  {{ block.shopify_attributes }}
>
  <ul class="-mx-2 flex flex-wrap items-start justify-start">
    {% if block.settings.linklist == empty %}
      {% for i in (1..3) %}
        <li class="mx-2 mb-2">
          <a
            href="#"
            class="theme-link text-theme-basic"
          >
            {{ 'products.product.onboarding.supporting_link' | t }}
            {{ i }}
          </a>
        </li>
      {% endfor %}
    {% else %}
      {% for supporting_link in block.settings.linklist.links %}
        <li class="break-word mx-2 mb-2">
          <a
            href="{{ supporting_link.url }}"
            class="theme-link text-theme-basic"
          >
            {{- supporting_link.title | escape | strip -}}
          </a>
        </li>
      {% endfor %}
    {% endif %}
  </ul>
</div>

{%- liquid
  unless preload
    assign preload = false
  endunless

  unless loading
    assign loading = null
  endunless

  unless decoding
    assign decoding = 'auto'
  endunless

  unless hidden_class
    assign hidden_class = 'md:hidden'
  endunless

  if split
    if split_media_style == 'cover'
      assign object_fit = 'md:object-cover'
    else
      assign object_fit = 'md:object-contain'
    endif
  endif

  assign enable_video_autoplay = false
  if section.settings.enable_video_autoplay == true and media.media_type == 'video'
    assign enable_video_autoplay = true
  endif
-%}

<div
  class="{% unless shown %} {{ hidden_class }} {% endunless %} {% if split %}h-full{% endif %}"
  {% unless outside_product_component %}
    {% unless always_shown %}
      :class="{ '{{ hidden_class }}' : currentMediaId !== {{ media.id }} }"
    {% endunless %}
    {% if scroll_to == true %}
      @media-visible.camel="!isUsingSlideshowToDisplayMedia && scrollToTopOf($el)"
    {% endif %}
    {% if media_item %}
      data-media-item
    {% endif %}
    data-product-single-media-wrapper="{{ media.id }}"
  {% endunless %}
>
  {% case media.media_type %}
    {% when 'video', 'external_video' %}
      {% liquid
        comment
          Shopify rounds 16/9 aspect ratios too much,
          resulting in some horizontal bars peeking through
        endcomment

        assign rounded_media_aspect_ratio_as_string = media.aspect_ratio | round: 2 | append: ''

        if rounded_media_aspect_ratio_as_string contains '1.77' or rounded_media_aspect_ratio_as_string contains '1.78'
          assign media_aspect_ratio = 1.77777778
        else
          assign media_aspect_ratio = media.aspect_ratio
        endif
      %}
      <div
        x-data="Video"
        {% if enable_video_autoplay %}
          x-init="enabled = true"
        {% endif %}
        id="video-{{ section.id }}-{{ media.id }}"
      >
        <div
          class="relative w-full {% if split %}h-full{% endif %}"
          {% unless split %}
            style="padding-top: {{ 100.00 | divided_by: media_aspect_ratio }}%;"
          {% endunless %}
          {% unless outside_product_component %}
            x-intersect:leave="!isUsingSlideshowToDisplayMedia && pause()"
            {% if enable_video_autoplay %}
              x-intersect:enter="play()"
            {% endif %}
          {% else %}
            x-intersect:leave="pause()"
            {% if enable_video_autoplay %}
              x-intersect:enter="play()"
            {% endif %}
          {% endunless %}
          {% if enable_video_autoplay %}
            x-data="enabled = true"
          {% endif %}
        >
          <template x-if="enabled">
            <div
              class="opacity-0 transition-opacity duration-500 {% if split %}h-full{% endif %}"
              :class="{ 'opacity-0': !shown, 'pointer-events-none': !shown }"
            >
              {% liquid
                assign video_object_class = 'video absolute inset-0 w-full h-full'
              %}
              {% case media.media_type %}
                {% when 'video' %}
                  {% if split %}
                    {% assign video_object_class = video_object_class
                      | append: ' md:h-full md:w-full md:object-cover '
                      | append: object_fit
                    %}
                  {% endif %}
                  <div
                    class="contents"
                    x-data="HTMLVideo"
                    @play="play"
                    @pause="pause"
                  >
                    {{
                      media
                      | video_tag:
                        loading: loading,
                        class: video_object_class,
                        image_size: '2000x',
                        controls: true,
                        autoplay: true,
                        loop: section.settings.enable_video_looping,
                        x-ref: 'video'
                    }}
                  </div>
                {% when 'external_video' %}
                  {% liquid
                    assign video_object_class = video_object_class | append: ' js-' | append: media.host
                  %}
                  {% case media.host %}
                    {% when 'youtube' %}
                      {% assign player_id = 'youtube-player-'
                        | append: section.id
                        | append: '-'
                        | append: media.id
                      %}
                      <div
                        class="contents"
                        x-data="YouTubeEmbed"
                        @play="play"
                        @pause="pause"
                      >
                        {{
                          media
                          | external_video_url:
                            enablejsapi: 1,
                            autoplay: true,
                            loop: section.settings.enable_video_looping,
                            playlist: media.external_id
                          | external_video_tag:
                            id: player_id,
                            class: video_object_class,
                            loading: loading,
                            x-ref: 'video',
                            alpineonloadattr: 'onIFrameLoad'
                          | replace: 'alpineonloadattr', 'x-on:load'
                        }}
                      </div>
                    {% when 'vimeo' %}
                      <div
                        class="contents"
                        x-data="VimeoEmbed"
                        @play="play"
                        @pause="pause"
                      >
                        {{
                          media
                          | external_video_url:
                            autoplay: true,
                            loop: section.settings.enable_video_looping
                          | external_video_tag:
                            class: video_object_class,
                            loading: loading,
                            x-ref: 'video'
                        }}
                      </div>
                  {% endcase %}
              {% endcase %}
            </div>
          </template>
          {% unless enable_video_autoplay == true %}
            <div
              class="group cursor-pointer transition-opacity duration-300 {% if split %}h-full{% endif %}"
              @click="enabled = true"
              :class="{ 'opacity-0' : shown, 'pointer-events-none': shown }"
            >
              <div class="absolute inset-0 h-full w-full">
                {% assign class = 'absolute inset-0 w-full h-full' %}
                {% if split %}
                  {% capture class %}absolute inset-0 w-full h-full {{ object_fit }}{% endcapture %}
                {% endif %}
                {{
                  media
                  | image_url: width: 2000
                  | image_tag:
                    sizes: sizes,
                    preload: preload,
                    loading: loading,
                    class: class,
                    decoding: decoding
                }}
              </div>
              <div class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-500 group-hover:opacity-30">
                <div class="h-full w-full bg-scheme-background"></div>
              </div>
              <button class="place-content-center absolute inset-0 grid h-full w-full">
                <span class="sr-only">{{ 'general.video.play' | t }}</span>
                <div class="scale-95 transition delay-150 duration-300 group-hover:scale-100">
                  <div class="h-16 w-16 border border-scheme-text/5 bg-scheme-background p-4">
                    <svg
                      aria-hidden="true"
                      focusable="false"
                      role="presentation"
                      class="h-full w-full fill-current"
                      viewBox="0 0 20 20"
                    >
                      <path d="M17 9.928L5 16.856V3l12 6.928z"></path>
                    </svg>
                  </div>
                </div>
              </button>
            </div>
          {% endunless %}
        </div>
        {% unless request.design_mode %}
          <script
            src="{{ 'video.js' | asset_url }}"
            type="module"
          ></script>
          {% case media.media_type %}
            {% when 'external_video' %}
              {% if media.host == 'youtube' %}
                <script
                  src="{{ 'youtube-embed.js' | asset_url }}"
                  type="module"
                ></script>
              {% elsif media.host == 'vimeo' %}
                <script
                  src="{{ 'vimeo-embed.js' | asset_url }}"
                  type="module"
                ></script>
              {% endif %}
            {% when 'video' %}
              <script
                src="{{ 'html-video.js' | asset_url }}"
                type="module"
              ></script>
          {% endcase %}
        {% endunless %}
      </div>
    {% when 'model' %}
      <div
        x-data="ThemeModule_Model"
        class="relative w-full"
        style="padding-top: 100%;"
        x-intersect.once="_init()"
      >
        <div x-show="!enabled">
          {{
            media
            | image_url: width: 1000
            | image_tag:
              class: 'absolute inset-0 w-full h-full',
              loading: 'lazy',
              decoding: decoding
          }}
        </div>
        <template x-if="enabled">
          {{
            media
            | model_viewer_tag:
              image_size: '1000x',
              reveal: 'interaction',
              toggleable: true,
              data-model-id: media.id,
              class: 'absolute inset-0 w-full h-full',
              background-color: 'white'
          }}
        </template>
      </div>

      {% unless request.design_mode %}
        <script
          src="{{ 'product-model.js' | asset_url }}"
          type="module"
        ></script>
      {% endunless %}
      <link
        id="ModelViewerStyle"
        rel="stylesheet"
        href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
        media="print"
        onload="this.media='all'"
      >
      {{ 'shopify-model-viewer-ui.css' | asset_url | stylesheet_tag }}
    {% else %}
      {% assign class = '' %}
      {% if split %}
        {% capture class %}md:h-full md:w-full {{ object_fit }} {% endcapture %}
      {% endif %}
      {{
        media
        | image_url: width: 2000
        | image_tag:
          sizes: sizes,
          preload: preload,
          loading: loading,
          class: class,
          decoding: decoding
      }}
  {% endcase %}
</div>

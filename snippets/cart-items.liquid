<div
  x-data="ThemeModule_CartItems"
  data-cart-items
  class="flex flex-auto flex-col"
>
  {% if cart != empty %}
    {%- liquid
      assign cart_item_grid_container = 'grid-cols-3 gap-2 auto-rows-max'

      if template == 'cart'
        assign cart_item_grid_container = cart_item_grid_container | append: ' lg:grid-cols-14'
      endif
    -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart">
      <div class="flex-auto py-4">
        {% if template == 'cart' %}
          <div class="sw-hidden lg:grid {{ cart_item_grid_container }} mb-5 items-end border-b border-scheme-text pb-5">
            <h1 class="font-heading text-2xl lg:col-span-8">
              {{ 'cart.general.title' | t }}
            </h1>
            <p class="justify-self-start lg:col-span-3">
              {{ 'cart.label.quantity' | t }}
            </p>
            <p class="justify-self-end lg:col-span-3">
              {{ 'cart.label.total' | t }}
            </p>
          </div>
        {% endif %}
        <ul
          :key="cart-items"
          class="cart-items-list grid grid-cols-1 gap-gutter"
        >
          {% for item in cart.items %}
            <li
              data-cart-item-key="{{ item.key }}"
              key="CartItem-{{ forloop.index }}-{{ item.key }}"
              class="grid {{ cart_item_grid_container }} py-2"
              :class="{ 'opacity-50': locked === $el }"
            >
              <div class="col-span-1 {% if template == 'cart' %} lg:col-span-2 lg:max-w-[166px] {% endif %} row-span-2 py-2">
                {% if item.image %}
                  <a
                    href="{{ item.url }}"
                    class="block"
                    aria-hidden="true"
                    tabindex="-1"
                  >
                    {{
                      item
                      | image_url: width: 200
                      | image_tag:
                        loading: 'eager',
                        sizes: '(min-width: 48em) 5rem, 3.5rem'
                    }}
                  </a>
                {% endif %}
              </div>
              <div class="p-2 {% if template == 'cart' %} lg:col-span-6 lg:row-span-2 {% endif %}">
                <div>
                  <a class="block" href="{{ item.url }}">
                    <div data-product-title>
                      <p class="font-heading break-word text-base leading-5 lg:text-lg lg:leading-6">
                        {{ item.product.title }}
                      </p>

                      {% unless item.product.has_only_default_variant %}
                        <p class="break-word mt-1 text-xs">
                          {{ item.variant.title }}
                        </p>
                      {% endunless %}
                    </div>

                    {% if settings.cart_vendor_enable %}
                      <p class="break-word mt-1 text-xs">{{ item.vendor }}</p>
                    {% endif %}

                    {% if item.selling_plan_allocation %}
                      <p class="break-word mt-1 text-xs">
                        {{ item.selling_plan_allocation.selling_plan.name }}
                      </p>
                    {% endif %}

                    {% unless item.properties == empty %}
                      {% for p in item.properties %}
                        {% assign first_character_in_key = p.first | slice: 0 %}
                        {% unless p.last == blank
                          or first_character_in_key == '_'
                        %}
                          <p class="break-word mt-1 text-xs">
                            {{ p.first }}:
                            {% if p.last contains '/uploads/' %}
                              <a href="{{ p.last }}">
                                {{- p.last | split: '/' | last -}}
                              </a>
                            {% else %}
                              {{ p.last }}
                            {% endif %}
                          </p>
                        {% endunless %}
                      {% endfor %}
                    {% endunless %}
                  </a>
                  {%- if item.line_level_discount_allocations != blank
                    or item.unit_price_measurement
                  -%}
                    <div
                      {% if template == 'cart' %}
                        class="lg:mb-1"
                      {% endif %}
                    >
                      {%- if item.line_level_discount_allocations != blank -%}
                        <ul
                          class="text-xs text-scheme-accent"
                          aria-label="{{ 'customer.order.discount' | t }}"
                        >
                          {%- for discount_allocation in item.line_level_discount_allocations -%}
                            <li class="order-discount__item break-word mt-1">
                              {{ discount_allocation.discount_application.title }}
                              {% if discount_allocation.amount > 0 -%}
                                (-{{ discount_allocation.amount | money }})
                              {%- endif %}
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                      {%- if item.unit_price_measurement -%}
                        <div class="mt-1 text-xs {% if item.original_price != item.final_price %} text-scheme-accent {% else %} text-scheme-secondary {% endif %}">
                          {{ item.unit_price | money }} /&nbsp;
                          {%- if item.unit_price_measurement.reference_value
                              != 1
                          -%}
                            {{- item.unit_price_measurement.reference_value -}}
                          {%- endif -%}
                          {{ item.unit_price_measurement.reference_unit }}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
                <div class="hidden {% if template == 'cart' %} lg:block {% endif %}">
                  <p class="text-xs {% if template == 'cart' %} lg:mt-3 {% endif %}">
                    <a
                      class="hover:text-scheme-accent"
                      href="{{ item.url_to_remove }}"
                      @click.prevent="remove()"
                    >
                      {{ 'cart.general.remove' | t: product: item.title }}
                    </a>
                  </p>
                </div>
              </div>
              <div class="col-span-2 flex flex-col {% if template == 'cart' %} lg:col-span-3 lg:row-span-2 {% endif %}">
                <div
                  class="my-1 hidden px-2 text-xs text-scheme-accent [text-wrap:balance] {% if template == 'cart' %} lg:order-2{% endif %}"
                  id="Line-item-error-{{ item.key }}"
                  role="alert"
                  data-item-title="{{ item.title | escape }}"
                  data-cart-quantity-error
                ></div>
                <div class="ml-[0.1rem] {% if template == 'cart' %} lg:flex lg:justify-start lg:ml-0 lg:order-1{% endif %}">
                  <label class="sr-only" for="updates_{{ item.key }}">
                    {{- 'cart.label.quantity' | t }}:</label
                  >
                  <div class="flex max-w-min flex-nowrap items-center justify-center">
                    <button
                      class="w-8 self-stretch"
                      aria-label="&minus;"
                      @click.prevent.stop="decrement()"
                    >
                      <div class="m-auto h-5 w-5">
                        {% render 'icon-minus' %}
                      </div>
                    </button>
                    <input
                      type="number"
                      class="w-20 border-0 text-center"
                      name="updates[]"
                      id="updates_{{ item.key }}"
                      value="{{ item.quantity }}"
                      size="4"
                      data-last-value="{{ item.quantity }}"
                      @change="itemQuantityChange()"
                      @keyup.debounce.750ms="$dispatch('change')"
                    >
                    <button
                      class="w-8 self-stretch"
                      aria-label="&plus;"
                      @click.prevent.stop="increment()"
                    >
                      <div class="m-auto h-5 w-5">{% render 'icon-plus' %}</div>
                    </button>
                  </div>
                </div>
                <div class="mt-2 p-2 {% if template == 'cart' %} lg:hidden {% endif %}">
                  <p class="text-xs">
                    <a
                      class="hover:text-scheme-accent"
                      href="{{ item.url_to_remove }} break-word"
                      @click.prevent="remove()"
                    >
                      {{ 'cart.general.remove' | t: product: item.title }}
                    </a>
                  </p>
                </div>
              </div>
              <div class="col-start-3 row-start-1 {% if template == 'cart' %}  lg:col-span-3 lg:row-span-2 {% endif %} p-2 text-right">
                {%- if item.original_line_price != item.final_line_price -%}
                  <del class="block">
                    {{- item.original_line_price | money -}}
                  </del>
                  <span class="block text-scheme-accent">
                    {{- item.final_line_price | money -}}
                  </span>
                {%- else -%}
                  {{ item.original_line_price | money }}
                {%- endif -%}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    </form>
  {% else %}
    <div class="py-section text-center">
      <p>{{ 'cart.general.empty' | t }}</p>
    </div>
  {% endif %}
</div>
<p
  class="sr-only"
  id="cart-live-region-text"
  aria-live="polite"
  role="status"
  aria-hidden="true"
>
  {{ 'cart.general.new_subtotal' | t }}:
  {{ cart.total_price | money_with_currency }}
</p>

{%- liquid
  unless video.alt == blank
    assign alt_text = video.alt
  else
    assign alt_text = 'general.video.video' | t
  endunless
-%}
<div
  x-data="
    {
      init() {
        this.$store.modals.register('{{ video_modal_id }}', 'modal');
        initTeleport(this.$root);
      },
      destroy() {
        this.$store.modals.close('{{ video_modal_id }}');
        delete this.$store.modals.modals['{{ video_modal_id }}'];
      }
    }
  "
>
  <div x-cloak>
    <template data-should-teleport="#modal-slot">
      <template x-if="$store.modals.modal.contents === '{{ video_modal_id }}'">
        <div
          data-modal-label="{{ alt_text | escape }}"
          class="h-full w-full"
        >
          <div class="fixed right-10 top-0 mt-5 flex items-center justify-between py-4">
            <h2 class="sr-only" class="" tabindex="-1">
              {{ alt_text | escape }}
            </h2>
            <button
              @click.prevent="$store.modals.close('{{ video_modal_id }}')"
              class="ml-auto block"
            >
              <span class="sr-only">
                {{- 'general.accessibility.close_modal' | t -}}
              </span>
              <span class="inline-block h-6 w-6">
                {%- render 'icon-close' -%}
              </span>
            </button>
          </div>
          <div
            class="flex h-full w-full"
            x-show="$store.modals.modal.contents === '{{ video_modal_id }}'"
          >
            <div
              x-data="Video('inline', 'autoplay')"
              id="video-in-{{ video_modal_id }}"
              class="aspect-h-9 aspect-w-16 relative m-auto w-9/12"
              @{{ video_modal_id }}-is-closed.window="pause"
            >
              <template x-if="enabled">
                <div
                  x-data="HTMLVideo"
                  class="transition-opacity duration-500"
                  :class="{ 'opacity-0': !shown, 'pointer-events-none': !shown }"
                  @play="play"
                  @pause="pause"
                >
                  {% if video %}
                    {{
                      video
                      | video_tag:
                        autoplay: true,
                        image_size: '2048x',
                        controls: true,
                        preload: 'none',
                        class: 'absolute inset-0 w-full h-full',
                        muted: false,
                        x-ref: 'video'
                    }}
                  {% else %}
                    <video
                      x-ref="video"
                      autoplay
                      class="absolute inset-0 h-full w-full"
                      controls
                    >
                      <source
                        src="{{ 'placeholder-video.mp4' | asset_url }}"
                        type="video/mp4"
                      >
                      Your browser does not support the video tag.
                    </video>
                  {% endif %}
                </div>
              </template>
              <div
                class="group cursor-pointer transition-opacity duration-300"
                :class="{ 'opacity-0' : shown, 'pointer-events-none': shown }"
                @click="enabled = true"
              >
                <div
                  class="absolute inset-0 h-full w-full bg-[#000]"
                ></div>
                <div class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-500 group-hover:opacity-30">
                  <div class="h-full w-full bg-scheme-background"></div>
                </div>
                <button class="place-content-center absolute inset-0 grid h-full w-full">
                  <span class="sr-only">
                    {{- 'general.video.play' | t -}}
                  </span>
                  <div class="scale-95 transition delay-150 duration-300 group-hover:scale-100">
                    <div class="h-16 w-16 rounded-full bg-scheme-background p-4">
                      {% render 'icon-play' %}
                    </div>
                  </div>
                </button>
              </div>
            </div>
          </div>
        </div>
      </template>
    </template>
  </div>
</div>

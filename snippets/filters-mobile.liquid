<template data-should-teleport="#left-drawer-slot">
  <div
    x-show="$store.modals.leftDrawer.contents === 'filters'"
    :data-modal-label="$store.modals.leftDrawer.contents === 'filters' ? '{{ 'facets.filters.title_tags' | t }}' : false"
    class="sidebar-filters py-6"
  >
    {%- liquid
      assign sort_by = results.sort_by | default: results.default_sort_by
      assign total_active_values = 0
      for filter in results.filters
        assign total_active_values = total_active_values | plus: filter.active_values.size
        if filter.type == 'price_range'
          if filter.max_value.value or filter.min_value.value
            assign total_active_values = total_active_values | plus: 1
          endif
        endif
      endfor
      if results.url
        assign results_url = results.url
      else
        assign terms = results.terms | escape
        assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
      endif
    -%}
    <div class="relative pb-4">
      <button
        @click.prevent="$store.modals.close('filters')"
        class="top-0 block"
      >
        <span class="sr-only">
          {{- 'general.accessibility.close_modal' | t -}}
        </span>
        <span class="inline-block h-6 w-6">{% render 'icon-close' %}</span>
      </button>
    </div>
    <form
      class="flex flex-auto flex-col"
      id="Facet-Filters-Form-Mobile"
      @submit.prevent="filterFormSubmit"
    >
      {%- if results.terms -%}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
        <input name="options[prefix]" type="hidden" value="last">
      {%- endif -%}
      <div class="-mx-5 flex-auto overflow-hidden overflow-y-auto px-5 py-4">
        {%- if show_sort -%}
          <div
            class="mb-5 mt-0"
            x-data="{ expanded : {{ expand_filters }} }"
          >
            <button
              type="button"
              class="font-secondary flex w-full items-center border-b border-scheme-text py-2 text-left text-base"
              :aria-expanded="expanded"
              @click="expanded = ! expanded"
              aria-controls="accordionSort"
            >
              {{ 'facets.sorting.title' | t }}
              <span
                class="svg-scale rotate ml-auto inline-block w-4 origin-center transform align-middle transition"
                :class="{ 'rotate-180' : expanded }"
              >
                {% render 'icon-chevron-down' %}
              </span>
            </button>
            <div id="accordionSort" x-show="expanded" x-collapse>
              <div class="pb-5">
                <ul class="mt-5">
                  {%- for option in collection.sort_options -%}
                    <li class="custom-radio mb-2 flex justify-start">
                      <input
                        type="radio"
                        class="sr-only absolute"
                        name="sort_by"
                        value="{{ option.value | escape }}"
                        id="Filter-Sort-{{ forloop.index0 }}-mobile"
                        {% if option.value == sort_by %}
                          checked
                        {% endif %}
                      >
                      <label
                        for="Filter-Sort-{{ forloop.index0 }}-mobile"
                        class="cursor-pointer {% if settings.links_uppercase %} uppercase {% elsif capitalize_filters %} capitalize {% endif %} flex items-center {% if filter_value.count == 0 and filter_value.active == false -%} text-scheme-secondary line-through {%- endif %}"
                        {% if filter_value.count == 0
                          and filter_value.active == false
                        -%}
                          disabled
                        {% endif %}
                      >
                        <span class="custom-radio__input"></span>
                        <span>
                          <span class="mr-1">{{ option.name | escape }}</span>
                        </span>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if show_filters -%}
          {%- for filter in results.filters -%}
            {%- liquid
              if enable_color_swatch_filters
                assign is_color = false
                assign swatch_trigger = 'products.product.color_swatch_trigger' | t | downcase
                assign filter_downcase = filter.label | downcase
                if filter_downcase contains swatch_trigger
                  assign is_color = true
                elsif swatch_trigger == 'color' and filter_downcase contains 'colour'
                  assign is_color = true
                endif
              endif

              if expand_filters
                assign expanded = 'true'
              elsif filter.active_values.size > 0
                assign expanded = 'true'
              elsif filter.type == 'price_range'
                if filter.min_value.value or filter.max_value.value
                  assign expanded = 'true'
                endif
              else
                assign expanded = 'false'
              endif

              assign presentation = filter.presentation
            -%}
            <div
              class="mb-4"
              x-data="{ expanded: {{ expanded }} }"
            >
              <button
                type="button"
                class="font-secondary flex w-full items-center border-b border-scheme-text py-2 text-left text-base"
                :aria-expanded="expanded"
                @click="expanded = ! expanded"
                aria-controls="accordion{{ forloop.index0 }}"
              >
                {{ filter.label }}
                {% if filter.active_values.size > 0 -%}
                  <span class="ml-1"> ({{ filter.active_values.size }})</span>
                {%- endif %}
                <span
                  class="svg-scale rotate ml-auto inline-block w-4 origin-center transform align-middle transition"
                  :class="{'rotate-180': expanded }"
                >
                  {%- render 'icon-chevron-down' -%}
                </span>
              </button>
              <div
                id="accordion{{ forloop.index0 }}"
                x-show="expanded"
                x-collapse
              >
                <div class="pb-4">
                  {%- case filter.type -%}
                    {%- when 'list', 'boolean' -%}
                      {% if presentation == 'image'
                        or presentation == 'swatch'
                      %}
                        <div class="-ml-1 mt-5 grid grid-cols-5 gap-2">
                          {%- for filter_value in filter.values -%}
                            <div class="variant-input relative inline-block">
                              <input
                                type="checkbox"
                                class="color-swatch peer absolute left-0 top-0 h-full w-full cursor-pointer opacity-0"
                                name="{{ filter_value.param_name }}"
                                value="{{ filter_value.value }}"
                                id="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                {% if filter_value.active %}
                                  checked
                                {% endif %}
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                %}
                                  disabled
                                {% endif %}
                              >
                              <label
                                for="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                class="border-1 rounded-swatches relative flex min-w-4 cursor-pointer items-center border border-scheme-text/30 p-1 peer-checked:border-scheme-text/100 {% if filter_value.count == 0 and filter_value.active == false -%} line-through {%- else -%} hover:text-scheme-accent {%- endif %}"
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                %}
                                  disabled
                                {% endif %}
                              >
                                {%- if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  <span
                                    class="absolute bottom-0 left-0 top-1/2 z-10 h-1 w-full -translate-y-1/2 -rotate-45 transform bg-scheme-text"
                                  ></span>
                                {%- endif -%}
                                {%- capture value_style -%}
                                  {%- if presentation == 'swatch' and filter_value.swatch.color != blank or filter_value.swatch.image != blank -%}
                                    {%- assign swatch_color = filter_value.swatch.color -%}
                                    {%- assign swatch_image = filter_value.swatch.image -%}
                                    background-position: {{ swatch_image.presentation.focal_point | default: 'center' }};{% if swatch_image != blank %} background-image: url({{ swatch_image | image_url: width: 120 }});{% else %}{% endif %}{% if swatch_color != blank %} background-color: rgb({{ swatch_color.rgb }});{% endif %}
                                  {%- elsif presentation == 'image' and filter_value.image != blank -%}
                                    {%- assign filter_value_image = filter_value.image -%}
                                    background-image: url({{ filter_value_image | image_url: width: 120 }}); background-position: {{ filter_value_image.presentation.focal_point | default: 'center' }};
                                  {%- endif -%}
                                {%- endcapture -%}
                                <div class="rounded-swatches w-full">
                                  <span
                                    class="color-swatch-input rounded-swatches block w-full bg-cover"
                                    style="padding-top: 100%; {{ value_style }}"
                                  ></span>
                                </div>
                                <span class="sr-only">
                                  {{- filter_value.label -}}
                                </span>
                              </label>
                            </div>
                          {%- endfor -%}
                        </div>
                      {% elsif is_color %}
                        <div class="-ml-1 mt-5 grid grid-cols-5 gap-2">
                          {%- for filter_value in filter.values -%}
                            {% liquid
                              assign color_image = filter_value.value | handle | append: '.' | append: 'png' | file_img_url: '160x' | prepend: 'https:'
                              assign color_swatch_fallback = filter_value.value | split: ' ' | last | handle
                            %}
                            <div class="variant-input relative inline-block">
                              <input
                                type="checkbox"
                                class="color-swatch peer absolute left-0 top-0 h-full w-full cursor-pointer opacity-0"
                                name="{{ filter_value.param_name }}"
                                value="{{ filter_value.value }}"
                                id="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                {% if filter_value.active -%}
                                  checked
                                {%- endif %}
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  disabled
                                {%- endif %}
                              >
                              <label
                                for="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                class="border-1 rounded-swatches relative flex min-w-4 cursor-pointer items-center border border-scheme-text/30 p-1 peer-checked:border-scheme-text/100 {% if filter_value.count == 0 and filter_value.active == false -%} line-through {%- else -%} hover:text-scheme-accent {%- endif %}"
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  disabled
                                {% endif %}
                              >
                                {%- if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  <span
                                    class="absolute bottom-0 left-0 top-1/2 z-10 h-1 w-full -translate-y-1/2 -rotate-45 transform bg-scheme-text"
                                  ></span>
                                {%- endif -%}
                                <div class="rounded-swatches w-full">
                                  <span
                                    class="color-swatch-input rounded-swatches block w-full bg-cover"
                                    style="padding-top: 100%; background-image: url({{ color_image }}); background-color: {{ color_swatch_fallback }};"
                                  ></span>
                                </div>
                                <span class="sr-only">
                                  {{- filter_value.label -}}
                                </span>
                              </label>
                            </div>
                          {%- endfor -%}
                        </div>
                      {% else %}
                        <ul class="mt-5">
                          {%- for filter_value in filter.values -%}
                            <li class="custom-checkbox mb-2 flex items-center justify-start">
                              <input
                                type="checkbox"
                                class="sr-only absolute"
                                name="{{ filter_value.param_name }}"
                                value="{{ filter_value.value }}"
                                id="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                {% if filter_value.active -%}
                                  checked
                                {%- endif %}
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  disabled
                                {%- endif %}
                              >
                              <label
                                for="Filter-{{ filter.label }}-{{ forloop.index0 }}-mobile"
                                class="cursor-pointer {% if settings.links_uppercase %}uppercase{% elsif capitalize_filters %}capitalize{% endif %} flex items-center {% if filter_value.count == 0 and filter_value.active == false -%}text-{{ section_color }}-meta line-through{%- else -%}hover:text-{{ section_color }}-accent{%- endif %}"
                                {% if filter_value.count == 0
                                  and filter_value.active == false
                                -%}
                                  disabled
                                {% endif %}
                              >
                                <span class="custom-checkbox__input"></span>
                                {{ filter_value.label }}
                                {% if show_filter_count %}
                                  <span class="ml-1 inline-block"
                                    >({{ filter_value.count }})</span
                                  >
                                {% endif %}
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {% endif %}
                    {%- when 'price_range' -%}
                      {% liquid
                        assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                        assign uses_comma_decimals = false
                        if currencies_using_comma_decimals contains cart.currency.iso_code
                          assign uses_comma_decimals = true
                        endif
                      %}
                      <div class="mx-auto mt-5 flex max-w-[25rem] items-center justify-between">
                        <div class="filter-group-display__price-range-from flex items-center justify-center">
                          <span class="pr-1">{{ cart.currency.symbol }}</span>
                          <div class="relative">
                            <input
                              name="{{ filter.min_value.param_name }}"
                              class="font-main w-28 border border-scheme-text bg-scheme-background p-1"
                              id="Filter-{{ filter.label | escape }}-GTE-mobile"
                              {%- if filter.min_value.value -%}
                                {%- if uses_comma_decimals -%}
                                  value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                                {%- else -%}
                                  value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                                {% endif %}
                              {%- endif -%}
                              type="number"
                              placeholder="{{ 'facets.filters.from' | t }}"
                              min="0"
                              max="{{ filter.range_max | divided_by: 100 | ceil }}"
                            >
                            <label
                              class="field__label sr-only"
                              for="Filter-{{ filter.label | escape }}-GTE-mobile"
                            >
                              {{- 'facets.filters.from' | t -}}
                            </label>
                          </div>
                        </div>
                        <div class="px-2">&ndash;</div>
                        <div class="filter-group-display__price-range-to  flex items-center justify-center">
                          <span class="pr-1">{{ cart.currency.symbol }}</span>
                          <div class="relative">
                            <input
                              name="{{ filter.max_value.param_name }}"
                              class="font-main block w-28 border border-scheme-text bg-scheme-background p-1"
                              id="Filter-{{ filter.label | escape }}-LTE-mobile"
                              {%- if filter.max_value.value -%}
                                {%- if uses_comma_decimals -%}
                                  value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                                {%- else -%}
                                  value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                                {% endif %}
                              {%- endif -%}
                              type="number"
                              placeholder="{{ 'facets.filters.to' | t }}"
                              min="0"
                              max="{{ filter.range_max | divided_by: 100 | ceil }}"
                            >
                            <label
                              class="field__label sr-only"
                              for="Filter-{{ filter.label | escape }}-LTE-mobile"
                            >
                              {{- 'facets.filters.to' | t -}}
                            </label>
                          </div>
                        </div>
                      </div>
                  {%- endcase -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="pb-safe-bottom pt-4 lg:pt-8 border-{{ section_color }}-border border-t-theme-width">
        <div class="mt-4 {% if total_active_values > 0 %}grid grid-cols-2 gap-5{% endif %}">
          <button type="submit" class="theme-button theme-button--solid w-full">
            <span>{{ 'facets.filters.apply' | t }}</span>
          </button>
          {% if total_active_values > 0 %}
            <a
              class="theme-button text-center"
              href="{{ results_url }}"
              @click.prevent="clearAllFilters(event)"
              ><span>{{ 'facets.filters.clear' | t }}</span></a
            >
          {% endif %}
        </div>
      </div>
    </form>
  </div>
</template>

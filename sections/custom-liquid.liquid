{%- unless section.settings.suppress_section_wrapper -%}
  {%- liquid
    assign section_color = section.settings.color_scheme | default: 'scheme1'
  -%}

  <section
    class="{% unless section.settings.remove_top_padding %}pt-section{% endunless %} {% unless section.settings.remove_bottom_padding %}pb-section{% endunless %} bg-scheme-background text-scheme-text {% if section.settings.disable_color_transition %}disable-section-color-transition disable-section-color-transition-source{% endif %}"
    data-color-scheme="{{ section_color }}"
  >
    <div
      {% unless section.settings.suppress_default_section_spacing %}
        class="mx-auto max-w-site px-5 lg:px-10"
      {% endunless %}
    >
      {{ section.settings.custom_liquid }}
    </div>
  </section>
{%- else -%}
  {{- section.settings.custom_liquid -}}
{%- endunless -%}

{% schema %}
{
  "name": "Custom Liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Custom Liquid",
      "info": "Add app snippets, other Liquid code, or HTML to create advanced customizations.",
      "default": "<p style=\"text-align: center;\">Add custom Liquid code.</p>"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "Color scheme"
    },
    {
      "type": "checkbox",
      "id": "disable_color_transition",
      "label": "Disable transition",
      "info": "Overrides section color transitions theme setting."
    },
    {
      "type": "header",
      "content": "Spacing",
      "info": "Adjust vertical spacing to visually connect this section to adjacent sections"
    },
    {
      "type": "checkbox",
      "id": "remove_top_padding",
      "label": "Remove top padding",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_bottom_padding",
      "label": "Remove bottom padding",
      "default": false
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "checkbox",
      "id": "suppress_section_wrapper",
      "label": "Suppress section wrapper",
      "info": "Will output the raw content of the liquid setting onto the page, without any spacing, colors or containers."
    }
  ],
  "presets": [
    {
      "name": "Custom Liquid"
    }
  ],
  "disabled_on": {
    "groups": [
      "aside"
    ]
  }
}
{% endschema %}

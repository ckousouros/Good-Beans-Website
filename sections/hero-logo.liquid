{%- liquid
  assign section_color = section.settings.color_scheme | default: 'scheme1'
  assign logo = ''

  assign enable_overlay = section.settings.enable_overlay
  assign position_underneath = section.settings.position_underneath

  if section.settings.logo == blank
    assign logo = settings.logo
  else
    assign logo = section.settings.logo
  endif

  if logo != blank
    case section.settings.alignment
      when 'left'
        assign alignment_classes = 'mr-auto'
      when 'right'
        assign alignment_classes = 'ml-auto'
      when 'center'
        assign alignment_classes = 'mx-auto'
    endcase

    assign sizes = section.settings.logo_max_width | append: 'vw'
  else
    case section.settings.alignment
      when 'left'
        assign alignment_classes = 'text-left'
      when 'right'
        assign alignment_classes = 'text-right'
      when 'center'
        assign alignment_classes = 'text-center'
    endcase
  endif

  if enable_overlay
    assign mobile_offset = section.settings.overlay_offset | times: 0.5
    assign desktop_offset = section.settings.overlay_offset
  endif
-%}

{%- if enable_overlay -%}
  {%- style -%}
    #{{ section.id }} {
      --overlay-offset: {{ mobile_offset }}px;
    }

    @media (min-width: 990px) {
      #{{ section.id }} {
        --overlay-offset: {{ desktop_offset }}px;
      }
    }

    {% if section.settings.home_page_only == false or template.name == 'index' %}
      {%- if position_underneath -%}
        #MainContent .shopify-section:first-of-type section[data-color-scheme].bg-scheme-background {
          background: transparent;
        }

        {% comment %}
          Add a layer of what would have been the section’s background
          to placeholder svgs so they’re not transparent
        {% endcomment %}
        #MainContent .shopify-section:first-of-type svg.bg-scheme-placeholder-background {
          --placeholder-bg-color: linear-gradient(to right, rgb(var(--color-scheme-text) / 0.05), rgb(var(--color-scheme-text) / 0.05));
          --section-bg-color: linear-gradient(to right, rgb(var(--color-scheme-background)), rgb(var(--color-scheme-background)));
          background-color: transparent;
          background-image: var(--placeholder-bg-color), var(--section-bg-color);
        }
      {%- endif -%}
    {% endif %}
  {%- endstyle -%}
{%- endif -%}

{%- if section.settings.home_page_only == false or template.name == 'index' -%}
  <section
    id="{{ section.id }}"
    class="bg-scheme-background text-scheme-text {% if section.settings.disable_color_transition %}disable-section-color-transition disable-section-color-transition-source{% endif %}"
    data-color-scheme="{{ section_color }}"
    role="complementary"
  >
    <div
      {% if enable_overlay %}
        {% unless position_underneath %}
          class="relative"
        {% endunless %}
        style="height: var(--overlay-offset);"
      {% endif %}
    >
      <div class="{% unless section.settings.remove_top_padding %}pt-half-section {% endunless %}{% unless section.settings.remove_bottom_padding %}pb-half-section {% endunless %}max-w-site mx-auto px-5 lg:px-10{% if enable_overlay and position_underneath == false %} absolute top-0 left-0 right-0 pointer-events-none z-20{% endif %}">
        {%- if logo != blank -%}
          {%- liquid
            assign logo_alt = logo.alt | default: shop.name | escape

            if section.location == 'header'
              assign preload = true
            else
              assign preload = false
            endif
          -%}
          <div
            class="{{ alignment_classes }}"
            style="max-width: {{ section.settings.logo_max_width }}%"
          >
            {%- assign logo_alt = logo.alt | default: shop.name | escape -%}
            {{
              logo
              | image_url: width: 3000
              | image_tag:
                class: 'w-full',
                width: logo.width,
                sizes: sizes,
                alt: logo_alt,
                preload: preload
            }}
          </div>
        {%- else -%}
          <div class="font-heading {% render 'type-scale-classes', mobile_text_scale: section.settings.mobile_text_scale, desktop_text_scale: section.settings.desktop_text_scale %} {{ alignment_classes }} break-word">
            {{ shop.name }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Hero logo",
  "settings": [
    {
      "type": "checkbox",
      "id": "home_page_only",
      "label": "Home page only",
      "default": true
    },
    {
      "type": "header",
      "content": "Plain text"
    },
    {
      "type": "range",
      "id": "mobile_text_scale",
      "min": -2,
      "max": 7,
      "step": 1,
      "label": "Mobile font size scale",
      "default": 2
    },
    {
      "type": "range",
      "id": "desktop_text_scale",
      "min": -2,
      "max": 10,
      "step": 1,
      "label": "Desktop font size scale",
      "default": 7
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "id": "logo",
      "type": "image_picker",
      "label": "Logo image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Logo max width",
      "default": 100
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable overlay",
      "default": false
    },
    {
      "type": "range",
      "id": "overlay_offset",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "px",
      "label": "Overlay offset",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "position_underneath",
      "label": "Position underneath first section",
      "info": "Enabling this will make the background of the first section transparent",
      "default": false
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "Color scheme"
    },
    {
      "type": "checkbox",
      "id": "disable_color_transition",
      "label": "Disable transition",
      "info": "Overrides section color transitions theme setting."
    },
    {
      "type": "header",
      "content": "Spacing",
      "info": "Adjust vertical spacing to visually connect this section to adjacent sections"
    },
    {
      "type": "checkbox",
      "id": "remove_top_padding",
      "label": "Remove top padding",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_bottom_padding",
      "label": "Remove bottom padding",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Hero logo"
    }
  ],
  "enabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}

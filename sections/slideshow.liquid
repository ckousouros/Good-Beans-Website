            },
            {
              "value": "md:text-left",
              "label": "Left"
            },
            {
              "value": "md:text-center",
              "label": "Center"
            },
            {
              "value": "md:text-right",
              "label": "Right"
            }
          ],
          "default": "inherit"
        },
        {
          "type": "header",
          "content": "Overlay text color"
        },
        {
          "type": "checkbox",
          "id": "enable_overlay_text_color_override",
          "label": "Override section color scheme"
        },
        {
          "type": "color_scheme",
          "id": "overlay_text_scheme",
          "label": "Text color override",
          "default": "scheme1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        {
          "type": "slide"
        },

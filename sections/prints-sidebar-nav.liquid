<aside class="prints-sidebar-nav">
  {% if section.settings.title != blank %}
    <h3 class="prints-sidebar-title">{{ section.settings.title }}</h3>
  {% endif %}
  <ul class="prints-sidebar-links">
    {% for link in linklists[section.settings.linklist].links %}
      <li class="prints-sidebar-item {% if link.url == request.path %}active{% endif %}">
        <a href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
</aside>

<style>
  .prints-sidebar-nav {
    width: 200px;
    min-width: 200px;
    padding: 20px 16px;
  }
  .prints-sidebar-title {
    font-weight: bold;
    margin-bottom: 16px;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  .prints-sidebar-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .prints-sidebar-item {
    margin-bottom: 12px;
  }
  .prints-sidebar-item a {
    text-decoration: none;
    font-size: 0.95rem;
  }
  .prints-sidebar-item.active a {
    font-weight: bold;
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .prints-sidebar-nav {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Prints Sidebar Nav",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Sidebar heading",
      "default": "Browse Prints"
    },
    {
      "type": "link_list",
      "id": "linklist",
      "label": "Navigation menu"
    }
  ],
  "presets": [
    {
      "name": "Prints Sidebar Nav"
    }
  ]
}
{% endschema %}

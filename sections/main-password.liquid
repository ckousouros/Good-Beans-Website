{%- liquid
  assign section_color = section.settings.color_scheme | default: 'scheme1'
-%}

<div
  class="fixed bottom-0 left-0 right-0 top-0 bg-scheme-background"
  data-color-scheme="{{ section_color }}"
>
  {%- if section.settings.background_image != blank %}
    {{
      section.settings.background_image
      | image_url: width: 2000
      | image_tag:
        class: 'block fixed inset-0 w-full h-full object-cover z-[-1]',
        preload: false,
        loading: 'lazy'
    }}
  {%- endif -%}
</div>

<section
  id="{{ section.id }}"
  class="relative text-scheme-text"
  data-color-scheme="{{ section_color }}"
  x-data
  x-init="
    initTeleport($root);
    $store.modals.register('password', 'modal');
  "
>
  <div class="fixed right-4 top-4">
    <button
      class="block h-6 w-6"
      @click="$store.modals.open('password')"
    >
      <span class="sr-only">
        {{- 'general.password_page.password_link' | t -}}
      </span>
      {% render 'icon-lock' %}
    </button>
  </div>
  <div class="flex min-h-screen">
    <div class="mx-auto my-auto min-w-[60%] max-w-site py-section">
      <div class="grid gap-x-grid-gutter lg:grid-cols-4">
        <div class="lg:col-span-1">
          <div class="flex pb-16 pl-5 pr-20 lg:px-0 lg:pb-0">
            {% if section.settings.logo != blank %}
              {% liquid
                assign logo = section.settings.logo
                assign logo_max_width = section.settings.logo_max_width
                assign logo_max_width_2x = section.settings.logo_max_width | times: 2
              %}
              {% style %}
                #{{ section.id }} {
                  --password-logo-max-width: {{ logo_max_width }}px;
                }
              {% endstyle %}
              <h1 class="break-word mr-auto md:ml-auto md:mr-0">
                <div class="max-w-[var(--password-logo-max-width)]">
                  <img
                    src="{{ logo | image_url: width: logo_max_width }}"
                    class="w-full"
                    loading="eager"
                    srcset="{{ logo | image_url: width: logo_max_width }} 1x, {{ logo | image_url: width: logo_max_width_2x }} 2x"
                    alt="{{ logo.alt | default: shop.name }}"
                    sizes="{{ logo_max_width }}px"
                    width="{{ logo.width }}"
                    height="{{ logo.height }}"
                  >
                </div>
              </h1>
            {% else %}
              <h1 class="font-heading mr-auto text-heading-standard md:ml-auto md:mr-0">
                {{ shop.name }}
              </h1>
            {% endif %}
          </div>
        </div>
        <div class="lg:col-span-3">
          <div class="px-5 lg:px-0">
            {% if section.settings.title != blank %}
              <h2 class="font-heading break-word text-xl">
                {{ section.settings.title | escape | strip }}
              </h2>

              {% comment %}
                Password message from store preferences
              {% endcomment %}

              {% unless shop.password_message == blank %}
                <div class="mt-5 text-theme-basic">
                  {{ shop.password_message }}
                </div>
              {% endunless %}

              {% if section.settings.newsletter_enable %}
                {% if section.settings.newsletter_form_heading != blank %}
                  <div class="rte rte--content-only rte--compact mt-5 text-theme-basic">
                    {{ section.settings.newsletter_form_heading }}
                  </div>
                {% endif %}
                <div class="mb-20 mt-5">
                  {% form 'customer' %}
                    {% if form.errors %}
                      <div class="needs-attention mb-5 text-sm">
                        {{ form.errors | default_errors }}
                      </div>
                    {% endif %}

                    {% if form.posted_successfully? %}
                      <p class="mb-5">
                        {{ 'general.newsletter_form.confirmation' | t }}
                      </p>
                    {% else %}
                      <div class="grid grid-cols-[1fr_auto]">
                        <input
                          type="hidden"
                          name="contact[tags]"
                          value="newsletter"
                        >
                        <label for="Email" class="sr-only">
                          {{ 'general.newsletter_form.newsletter_email' | t }}
                        </label>
                        <input
                          type="email"
                          name="contact[email]"
                          id="Email"
                          class="text-theme-basic {% if form.errors %} border-scheme-error {% else %} border-scheme-text {% endif %}"
                          value="{% if customer %}{{ customer.email }}{% endif %}"
                          placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}"
                          autocorrect="off"
                          autocapitalize="off"
                        >
                        <button
                          type="submit"
                          class="theme-button theme-button--solid ml-3 md:ml-5"
                        >
                          <span class="text-theme-basic">
                            {{ 'general.newsletter_form.submit' | t }}
                          </span>
                        </button>
                      </div>
                    {% endif %}
                  {% endform %}
                </div>
              {% endif %}
            {% endif %}
            {% if section.settings.show_share_buttons %}
              <div class="mt-10">
                {% render 'page-share' %}
              </div>
            {% endif %}
            <div class="mt-10 text-xs">
              {{ powered_by_link }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div x-cloak>
    <template data-should-teleport="#modal-slot">
      <div x-show="$store.modals.modal.contents === 'password'">
        <div
          :data-modal-label="$store.modals.modal.contents === 'password' ? '{{ 'general.password_page.login_form_heading' | t }}' : null"
          class="flex h-full min-h-screen w-full"
        >
          <button
            @click.prevent="$store.modals.close('password')"
            class="fixed right-10 ml-auto mt-5 block pt-4"
          >
            <span class="sr-only">
              {{- 'general.accessibility.close_modal' | t -}}
            </span>
            <span class="inline-block h-6 w-6">{% render 'icon-close' %}</span>
          </button>
          <div class="mx-auto my-auto min-w-[40%] max-w-site py-section">
            <h2 class="font-heading mt-5 text-2xl">
              {{ 'general.password_page.login_form_heading' | t }}
            </h2>

            {% form 'storefront_password' %}
              {% if form.errors %}
                <div
                  class="mb-6 mt-2 text-sm"
                  x-data
                  x-init="$store.modals.open('password');"
                ></div>
                <div
                  class="needs-attention mb-6 mt-2 text-sm"
                  x-data
                  x-init="$store.modals.open('password');"
                >
                  {{ form.errors | default_errors }}
                </div>
              {% endif %}
              <label for="Password" class="mt-5 block">
                {{ 'general.password_page.login_form_password_label' | t }}
              </label>
              <div class="grid grid-cols-[1fr_auto]">
                <input
                  type="password"
                  name="password"
                  id="Password"
                  class="text-theme-basic"
                >
                <button
                  type="submit"
                  class="theme-button theme-button--solid ml-3 md:ml-5"
                >
                  <span class="text-theme-basic">
                    {{ 'general.password_page.login_form_submit' | t }}
                  </span>
                </button>
              </div>
            {% endform %}
            <p class="mt-10 text-sm">
              {{ 'general.password_page.admin_link_html' | t }}
            </p>
          </div>
        </div>
      </div>
    </template>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 20,
      "max": 450,
      "step": 10,
      "unit": "px",
      "label": "Custom logo width",
      "default": 250
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "id": "background_image",
      "type": "image_picker",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "richtext",
      "id": "newsletter_form_heading",
      "label": "Newsletter form heading",
      "default": "<p>Be the first to know when we launch.</p>",
      "info": "[Tell your visitors about a launch day discount](https://www.shopify.com/blog/15514000-14-ways-to-use-offers-coupons-discounts-and-deals-to-drive-revenue-and-customer-loyalty)"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Newsletter placeholder text",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "label": "Newsletter button text",
      "default": "Submit"
    },
    {
      "type": "header",
      "content": "Social sharing"
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show social media sharing buttons",
      "default": true
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "Color scheme"
    }
  ]
}
{% endschema %}

        {
          "value": "portrait",
          "label": "Portrait"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "image_align_vertical",
      "label": "Vertical alignment on desktop",
      "default": "center",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_align_horizontal",
      "label": "Horizontal alignment on desktop",

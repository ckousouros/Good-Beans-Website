    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Height on desktop",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "full_screen",
          "label": "Full screen"
        }
      ]
    },
    {
      "type": "select",

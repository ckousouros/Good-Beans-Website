{%- liquid
  assign section_color = section.settings.color_scheme

  if section.index == 1
    assign preload = true
  else
    assign preload = false
  endif

  if section.index <= 3
    assign loading = 'eager'
  else
    assign loading = 'lazy'
  endif

  assign section_desktop_layout = section.settings.section_desktop_layout

  assign image_width = section.settings.image_width | split: '|' | first | strip
  assign content_width = section.settings.image_width | split: '|' | last | strip

  assign image_height = section.settings.image_height

  assign image_align_vertical = section.settings.image_align_vertical
  assign image_align_horizontal = section.settings.image_align_horizontal

  case section.settings.image_full_bleed
    when 'none'
      assign image_full_bleed_on_mobile = false
      assign image_full_bleed_on_desktop = false
    when 'mobile_only'
      assign image_full_bleed_on_mobile = true
      assign image_full_bleed_on_desktop = false
    when 'mobile_and_desktop'
      assign image_full_bleed_on_mobile = true
      assign image_full_bleed_on_desktop = true
  endcase

  if image_full_bleed_on_desktop
    assign image_top_class = 'lg:top-0'

    if image_height == 'auto'
      assign image_height_class = 'lg:max-h-screen'
    else
      assign image_height_class = 'lg:h-screen'
    endif
  else
    assign image_top_class = 'lg:top-sticky-header-height'

    if image_height == 'auto'
      assign image_height_class = 'lg:max-h-screen-less-sticky-header'
    else
      assign image_height_class = 'lg:h-screen-less-sticky-header'
    endif
  endif

  assign image_crop = section.settings.image_crop

  if image_crop == 'none'
    assign image_class = image_height_class | append: ' lg:object-cover'
  else
    assign image_class = ''
  endif

  if image_align_horizontal != 'full_width'
    assign horizontal_alignment_class = ' lg:w-3/4'

    case image_align_horizontal
      when 'left'
        assign horizontal_alignment_class = horizontal_alignment_class | append: ' lg:mr-auto'
      when 'center'
        assign horizontal_alignment_class = horizontal_alignment_class | append: ' lg:mx-auto'
      when 'right'
        assign horizontal_alignment_class = horizontal_alignment_class | append: ' lg:ml-auto'
    endcase
  endif

  case image_align_vertical
    when 'top'
      assign vertical_alignment_class = ' lg:self-start'
    when 'center'
      assign vertical_alignment_class = ' lg:self-center'
    when 'bottom'
      assign vertical_alignment_class = ' lg:self-end'
  endcase

  case image_width
    when 'lg:col-span-4'
      # One third
      assign image_sizes = '33.3vw'
    when 'lg:col-span-5'
      # Two fifths
      assign image_sizes = '40vw'
    when 'lg:col-span-4'
      # One half
      assign image_sizes = '50vw'
    when 'lg:col-span-7'
      # Three fifths
      assign image_sizes = '60vw'
  endcase

  assign desktop_layout = section.settings.desktop_layout
  assign alignment_variation = section.settings.alignment_variation
  assign force_one_column_align_to_media = section.settings.force_one_column_align_to_media

  if force_one_column_align_to_media
    assign desktop_layout = 'single_column'
    if section_desktop_layout == 'image_left'
      assign alignment_variation = 'align_items_left'
    else
      assign alignment_variation = 'align_items_right'
    endif
  endif

  assign enable_cascade_on_mobile = section.settings.enable_cascade_on_mobile

  assign video_blocks = section.blocks | where: 'type', 'video'

  assign multi_item_block_types = 'product_list,collection_list' | split: ','

  assign full_width_item_header = '||__cascade-item:full__||'
  assign item_separator = '||__cascade-item-end__||'

  if desktop_layout == 'two_columns'
    case content_width
      when 'lg:col-span-8'
        # Two thirds (“One third” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 35vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 55vw'
      when 'lg:col-span-7'
        # Three fifths (“Two fifths” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 30vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 50vw'
      when 'lg:col-span-6'
        # One half (“One half” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 25vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 40vw'
      when 'lg:col-span-5'
        # Two fifths (“Three fifths” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 20vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 33vw'
    endcase
  else
    case content_width
      when 'lg:col-span-8'
        # Two thirds (“One third” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 40vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 55vw'
      when 'lg:col-span-7'
        # Three fifths (“Two fifths” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 45vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 50vw'
      when 'lg:col-span-6'
        # One half (“One half” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 37.5vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 40vw'
      when 'lg:col-span-5'
        # Two fifths (“Three fifths” image width)
        assign content_half_width_desktop_sizes = '(min-width: 768px) 30vw'
        assign content_full_width_desktop_sizes = '(min-width: 768px) 33vw'
    endcase
  endif

  if enable_cascade_on_mobile
    assign content_half_width_mobile_sizes = '75vw'
  else
    assign content_half_width_mobile_sizes = '100vw'
  endif

  assign content_half_width_sizes = content_half_width_desktop_sizes | append: ', ' | append: content_half_width_mobile_sizes

  if enable_cascade_on_mobile
    assign content_full_width_mobile_sizes = '80vw'
  else
    assign content_full_width_mobile_sizes = '100vw'
  endif

  assign content_full_width_sizes = content_full_width_mobile_sizes | append: ', ' | append: content_full_width_desktop_sizes

  if enable_cascade_on_mobile
    assign content_eager_loading_limit = section.blocks.size | at_most: 4
  else
    assign content_eager_loading_limit = section.blocks.size | at_most: 2
  endif

  capture cascade_block_items
    for block in section.blocks
      assign content_loading = 'lazy'

      if section.index <= 2 and forloop.index <= content_eager_loading_limit
        assign content_loading = 'eager'
      endif

      unless multi_item_block_types contains block.type
        if block.settings.block_width == 'full'
          echo full_width_item_header
          assign content_sizes = content_full_width_sizes
        else
          assign content_sizes = content_half_width_sizes
        endif

        render 'cascade-block-content' with block as block, enable_cascade_on_mobile: enable_cascade_on_mobile, index: forloop.index0, full_width_item_header: full_width_item_header, sizes: content_sizes, preload: false, loading: content_loading
        echo item_separator
      else
        render 'cascade-multi-item-block-content' with block as block, enable_cascade_on_mobile: enable_cascade_on_mobile, index: forloop.index0, full_width_item_header: full_width_item_header, sizes: content_sizes, preload: false, loading: content_loading
      endunless
    endfor
  endcapture

  assign top_padding_class = ''
  assign bottom_padding_class = ''

  if image_full_bleed_on_mobile
    if section.settings.remove_bottom_padding
      assign bottom_padding_class = ''
    else
      assign bottom_padding_class = 'pb-section'
    endif
  else
    unless section.settings.remove_top_padding
      assign top_padding_class = 'pt-section'
    endunless

    unless section.settings.remove_bottom_padding
      assign bottom_padding_class = 'pb-section'
    endunless
  endif

  if image_full_bleed_on_desktop
    assign top_padding_class = top_padding_class | append: ' lg:pt-0'

    assign bottom_padding_class = bottom_padding_class | append: ' lg:pb-0'
  else
    unless section.settings.remove_top_padding
      assign top_padding_class = top_padding_class | append: ' lg:pt-section'
    endunless

    unless section.settings.remove_bottom_padding
      assign bottom_padding_class = bottom_padding_class | append: ' lg:pb-section'
    endunless
  endif
-%}

<section
  class="{{ top_padding_class }} {{ bottom_padding_class }} bg-scheme-background px-5 text-scheme-text lg:px-10 {% if section.settings.disable_color_transition %}disable-section-color-transition disable-section-color-transition-source{% endif %}"
  data-color-scheme="{{ section_color }}"
  x-data
>
  <div class="relative">
    {% if section.settings.title != blank %}
      {%- render 'cascade-heading',
        title: section.settings.title,
        overlay_heading: section.settings.overlay_heading,
        mobile_text_scale: section.settings.heading_mobile_text_scale,
        desktop_text_scale: section.settings.heading_desktop_text_scale,
        cta_link: section.settings.overlay_cta_link,
        cta_label: section.settings.overlay_cta_label,
        cta_style: section.settings.overlay_cta_style,
        blend_mode: section.settings.blend_mode,
        blend_mode_color_scheme: section.settings.blend_mode_color_scheme
      -%}
    {% endif %}
    <div class="lg:grid lg:grid-cols-12 max-lg:space-y-5 {% unless image_full_bleed_on_desktop %}lg:gap-10{% endunless %}">
      <div
        class="{{ image_width }} {% if image_crop == 'none' and image_height != 'auto' %}lg:h-fit{% else %}{{ image_height_class }}{% endif %} bg-scheme-background lg:sticky {{ image_top_class }} {% if image_full_bleed_on_mobile %}max-lg:-mx-5{% endif %} {% if image_full_bleed_on_desktop %}{% if section_desktop_layout == 'image_left' %} lg:-ml-10{% else %} lg:-mr-10{% endif %}{% endif %}{% if section_desktop_layout == 'image_right' %} order-2{% endif %} flex"
      >
        <div class="w-full {{ horizontal_alignment_class }} {{ vertical_alignment_class }}">
          <div class="image-wrapper image-wrapper-{{ image_crop }}">
            {% if section.settings.image != blank %}
              {% assign image = section.settings.image %}
              {{
                image
                | image_url: width: 2000
                | image_tag:
                  sizes: image_sizes,
                  preload: preload,
                  loading: loading,
                  class: image_class
              }}
            {% else %}
              {{
                'image'
                | placeholder_svg_tag: 'bg-scheme-placeholder-background text-scheme-placeholder-foreground fill-current'
              }}
            {% endif %}
          </div>
        </div>
      </div>
      <div
        class="{{ content_width }} lg:my-auto lg:h-fit bg-scheme-background{% if image_full_bleed_on_desktop %} lg:pt-section lg:pb-section{% endif %}{% if section_desktop_layout == 'image_right' %} order-1{% endif %}{% if image_full_bleed_on_desktop %}{% if section_desktop_layout == 'image_left' %} lg:pl-10{% else %} lg:pr-10{% endif %}{% endif %}"
      >
        {% render 'cascade',
          content_items: cascade_block_items,
          alternate_first_block_position: true,
          enable_cascade_on_mobile: enable_cascade_on_mobile,
          desktop_layout: desktop_layout,
          level_of_media_size_variation: section.settings.level_of_media_size_variation,
          sequence: section.settings.sequence,
          alignment_variation: alignment_variation,
          spacing: section.settings.spacing,
          first_block_position: section.settings.start_position,
          use_global_settings: section.settings.use_global_settings
        %}
      </div>
    </div>
  </div>

  {% liquid
    for block in video_blocks
      assign has_video_blocks = true

      if block.settings.mode == 'preview' and block.settings.playback == 'modal'
        assign video_modal_id = 'video-modal-' | append: section.id | append: '-' | append: block.id | replace: '_', '-' | handleize
        assign video = block.settings.video

        render 'video-modal', video: video, video_modal_id: video_modal_id
      endif
    endfor
  %}

  {% if has_video_blocks %}
    {% unless request.design_mode %}
      <script
        src="{{ 'video.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'html-video.js' | asset_url }}"
        type="module"
      ></script>
    {% endunless %}
  {% endif %}
</section>

{% schema %}
{

{% liquid
  assign section_color = section.settings.color_scheme
  assign media_position_on_desktop = section.settings.media_position_on_desktop
  if media_position_on_desktop == 'right'
    assign media_position_class = 'md:order-last'
  endif
  assign enable_thumbnails_on_desktop = section.settings.enable_thumbnails_on_desktop
  assign thumbnails_width_on_desktop = section.settings.thumbnails_width_on_desktop

  assign product_media_col_span = section.settings.media_width_on_desktop | plus: 0
  assign product_content_col_span = 12 | minus: product_media_col_span

  assign product_content_max_width = 'max-w-full'

  if section.settings.product_content_width_on_desktop == 'narrow'
    case product_content_col_span
      when 6
        # 1/2
        assign product_content_max_width = 'md:max-w-[50%]'
        assign content_desktop_sizes_base = '25vw'
      when 5
        # “2/5” (5/12)
        assign product_content_max_width = 'md:max-w-[60%]'
        assign content_desktop_sizes_base = 'calc(42vw * 0.6)'
      when 4
        # 1/3
        assign product_content_max_width = 'md:max-w-[75%]'
        assign content_desktop_sizes_base = 'calc(33.4vw * 0.75)'
      when 3
        # 1/4
        assign product_content_max_width = 'lg:max-w-[80%]'
        assign content_desktop_sizes_base = 'calc(25vw * 0.8)'
    endcase
  else
    case product_content_col_span
      when 6
        # 1/2
        assign content_desktop_sizes_base = '50vw'
      when 5
        # 5/12
        assign content_desktop_sizes_base = '42vw'
      when 4
        # 1/3
        assign content_desktop_sizes_base = '33.4vw'
      when 3
        # 1/4
        assign content_desktop_sizes_base = '25vw'
    endcase
  endif

  if thumbnails_width_on_desktop == 'small'
    assign product_media_grid_class = 'md:grid-cols-[fit-content(6rem)_1fr_1fr_1fr_1fr]'
    if media_position_on_desktop == 'right'
      assign product_media_grid_class = 'md:grid-cols-[1fr_1fr_1fr_1fr_fit-content(6rem)]'
    endif
  else
    assign product_media_grid_class = 'md:grid-cols-5'
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media

  assign models = product.media | where: 'media_type', 'model'

  for media in product.media
    if media.media_type != 'image'
      assign has_interactive_media = true
      break
    endif
  endfor

  assign enable_image_zoom = section.settings.enable_image_zoom

  assign product_form_id = 'product-form-' | append: section.id

  assign popup_blocks = section.blocks | where: 'type', 'popup'

  assign tallest_media_aspect_ratio = product.media | map: 'aspect_ratio' | sort | first

  case product_media_col_span
    when 6
      # 1/2
      assign media_desktop_sizes_base = '50vw'
    when 7
      # “3/5” (7/12)
      assign media_desktop_sizes_base = '58vw'
    when 8
      # 2/3
      assign media_desktop_sizes_base = '66.7vw'
    when 9
      # 3/4
      assign media_desktop_sizes_base = '75vw'
  endcase
%}

{% unless request.design_mode %}
  <script
    src="{{ 'vendor-product.bundle.min.js' | asset_url }}"
    type="module"
  ></script>
  <script src="{{ 'product.js' | asset_url }}" type="module"></script>
{% endunless %}

<style>
  #{{ section.id }} {
    /* Calculate the width of the featured media item ... */
    --max-possible-width: min(var(--max-site-width), 100vw);
    --grid-width: calc(var(--max-possible-width) - (2.5rem * 2));
    --grid-column-width: calc((var(--grid-width) - (var(--grid-gutter) * 11)) / 12);

    --media-column-cols: {{ product_media_col_span }};
    --media-column-width: calc(var(--media-column-cols) * var(--grid-column-width) + (var(--grid-gutter) * (var(--media-column-cols) - 1)));

    --media-grid-container-cols: 5;
    --media-grid-gutter: 1rem;
    --featured-media-cols: 4;
    {% if thumbnails_width_on_desktop == 'small' %}
      --first-column-width: 6rem;
      --featured-media-width: calc((var(--media-column-width) - var(--first-column-width) - (4 * var(--media-grid-gutter))) + (3 * var(--media-grid-gutter)));
    {% else %}
      --media-grid-column-width: calc((var(--media-column-width) - (4 * var(--media-grid-gutter))) / 5);
      --featured-media-width: calc((var(--featured-media-cols) * var(--media-grid-column-width)) + ((var(--featured-media-cols) - 1) * var(--media-grid-gutter)));
    {% endif %}

    /* ... grab the tallest aspect ratio in product media ... */
    --tallest-media-aspect-ratio: {{ tallest_media_aspect_ratio }};
    /* ... calculate the tallest media’s height in vw and apply to thumbnails */
    --thumbnails-height: calc(var(--featured-media-width) / var(--tallest-media-aspect-ratio));
  }
</style>

<section
  class="bg-scheme-background text-scheme-text"
  data-color-scheme="{{ section_color }}"
  id="{{ section.id }}"
  x-data="
    Theme_Product({
      product: {{ product | json | escape }},
      variant: {{ current_variant | json | escape }},
      featuredMediaId: {% if featured_media %}{{ featured_media.id }}{% else %}null{% endif %},
      enableThumbnailsOnDesktop: {{ enable_thumbnails_on_desktop | json }}
    })
  "
  data-product-section
  @product-url-update.stop="window.history.replaceState({ path: $event.detail.url }, '', $event.detail.url);"
>
  <div class="z-10 mx-auto max-w-site px-5 py-section lg:px-10">
    <div class="relative">
      <div
        class="grid gap-half-section md:grid-cols-12 md:gap-grid-gutter"
      >
        <div
          class="md:col-span-item {{ media_position_class }} md:grid {{ product_media_grid_class }} md:gap-4"
          style="--item-col-span: {{ product_media_col_span }};"
        >
          {% if product.media.size > 0 %}
            {% liquid
              if enable_thumbnails_on_desktop and thumbnails_width_on_desktop == 'grow'
                assign desktop_sizes = 'calc(' | append: media_desktop_sizes_base | append: ' * 4 / 5)'
              else
                assign desktop_sizes = media_desktop_sizes_base
              endif

              assign sizes = '(min-width: 990px) ' | append: desktop_sizes | append: ', 100vw'
            %}
            {% if product.media.size == 1 %}
              <div class="md:col-span-5">
                {% if enable_image_zoom
                  and featured_media.media_type == 'image'
                %}
                  <a
                    href="{{ featured_media.url }}"
                    class="cursor-zoom-in"
                    role="button"
                    @click.prevent="openZoom({{ featured_media.id }})"
                  >
                {% endif %}
                {% render 'media',
                  media: featured_media,
                  sizes: sizes,
                  shown: true,
                  preload: true,
                  loading: 'eager',
                  enable_video_autoplay: section.settings.enable_video_autoplay
                %}
                {% if enable_image_zoom
                  and featured_media.media_type == 'image'
                %}
                  </a>
                {% endif %}
              </div>
            {% elsif product.media.size > 1 %}
              {% if enable_thumbnails_on_desktop %}
                <div
                  class="sw-hidden md:col-span-1 md:block {% if media_position_on_desktop == 'right' %} md:order-2 {% endif %}"
                >
                  <div
                    id="slideshow-thumbnails-{{ section.id }}"
                    class="splide splide--thumbnails max-h-[--thumbnails-height] [&:not(.is-active)]:overflow-hidden"
                    x-data="
                      {
                        firstVisible: true,
                        lastVisible: true,
                        topOfThumbsVisible: true,
                        bottomOfThumbsVisible: true,
                        get firstScrolledOut() {
                          return (this.topOfThumbsVisible === true && this.firstVisible === false)
                        },
                        get lastScrolledOut() {
                          return (this.bottomOfThumbsVisible === true && this.lastVisible === false)
                        }
                      }
                    "
                  >
                    <div class="splide__track">
                      <button
                        type="button"
                        class="thumbnails-rewind-top custom-focus absolute left-0 right-0 top-0 z-[3] block w-full"
                        :class="{ 'opacity-0 pointer-events-none' : ! firstScrolledOut, 'cursor-pointer' : firstScrolledOut }"
                        @click="window.slideshows[`${$root.id}`].go(0)"
                      ></button>
                      <div
                        class="thumbnails-overflow-indicator-top pointer-events-none absolute left-0 right-0 top-0 z-[2] h-24 w-full bg-gradient-to-b from-scheme-background to-transparent opacity-0 transition-opacity duration-150"
                        x-intersect:enter.full="topOfThumbsVisible = true"
                        x-intersect:leave.full="topOfThumbsVisible = false"
                        :class="{ 'opacity-0' : ! firstScrolledOut }"
                        x-cloak
                      ></div>
                      <ul
                        class="splide__list w-full [.splide:not(.is-active)_&]:space-y-5"
                        role="list"
                      >
                        {%- liquid
                          if thumbnails_width_on_desktop == 'small'
                            assign thumbnail_sizes = '6rem'
                          else
                            assign thumbnail_sizes = 'calc(50vw / 5)'
                          endif
                          for media in product.media
                            assign thumbnail_loading = 'lazy'

                            assign eager_loading_limit = featured_media.position | plus: 5

                            if media.id == featured_media.id or media.position <= eager_loading_limit
                              assign thumbnail_loading = 'eager'
                            endif

                            render 'media-thumbnail', media: media, class: 'splide__slide w-full', first: forloop.first, last: forloop.last, loading: thumbnail_loading, sizes: thumbnail_sizes
                          endfor
                        -%}
                      </ul>
                      <button
                        type="button"
                        class="thumbnails-ffwd-bottom custom-focus absolute bottom-0 left-0 right-0 z-[3] block w-full"
                        :class="{ 'opacity-0 pointer-events-none' : ! lastScrolledOut, 'cursor-pointer' : lastScrolledOut }"
                        x-intersect:enter.full="bottomOfThumbsVisible = true"
                        x-intersect:leave.full="bottomOfThumbsVisible = false"
                        @click="
                          window.slideshows[`${$root.id}`].go(
                            window.slideshows[`${$root.id}`].Components.Slides.getLength()
                          );
                        "
                      ></button>
                      <div
                        class="thumbnails-overflow-indicator-bottom pointer-events-none absolute bottom-0 left-0 right-0 z-[2] h-24 w-full bg-gradient-to-t from-scheme-background to-transparent opacity-0 transition-opacity duration-150"
                        :class="{ 'opacity-0' : ! lastScrolledOut }"
                      ></div>
                    </div>
                  </div>
                </div>
              {% endif %}
              <div class="col-span-5 {% if enable_thumbnails_on_desktop %}md:col-span-4{% endif %}">
                <div
                  id="slideshow-{{ section.id }}"
                  class="splide splide--product"
                  data-drag-disabled="{{ has_interactive_media }}"
                  data-first-media="{{ featured_media.id }}"
                  {% if enable_thumbnails_on_desktop %}
                    data-thumbnails="slideshow-thumbnails-{{ section.id }}"
                    data-desktop-product-splide="no-controls"
                  {% endif %}
                >
                  <div class="splide__track -mx-5 mb-4 md:mx-0 {% if enable_thumbnails_on_desktop %}md:mb-0{% endif %}">
                    <ul class="splide__list w-full" role="list">
                      {% for media in product.media %}
                        {% liquid
                          assign preload = false
                          assign loading = 'lazy'

                          assign eager_loading_limit = featured_media.position | plus: 4

                          if media.id == featured_media.id
                            if section.index == 1
                              assign preload = true
                            endif

                            if section.index <= 3
                              assign loading = 'eager'
                            endif
                          else
                            if section.index <= 2 and media.position <= eager_loading_limit
                              assign loading = 'eager'
                            endif
                          endif
                        %}
                        <li
                          class="splide__slide block w-3/4 px-5 md:w-full md:px-0 {% unless media.id == featured_media.id %}[.splide:not(.is-active,_.is-initialized)_&]:hidden{% endunless %}"
                          data-media-id="{{ media.id }}"
                        >
                          {% if enable_image_zoom
                            and media.media_type == 'image'
                          %}
                            <a
                              href="{{ media.url }}"
                              role="button"
                              class="cursor-zoom-in"
                              @click.prevent="openZoom({{ media.id }})"
                            >
                          {% endif %}
                          {%
                            render 'media',
                            media: media,
                            sizes: sizes,
                            shown: true,
                            always_shown: true,
                            preload: preload,
                            loading: loading,
                          %}
                          {% if enable_image_zoom
                            and media.media_type == 'image'
                          %}
                            </a>
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                  {% assign first_3d_model = product.media
                    | where: 'media_type', 'model'
                    | first
                  %}
                  {%- if first_3d_model -%}
                    <div class="col-span-2 mb-4">
                      <button
                        aria-label="{{ 'products.media.view_in_your_space_label' | t }}"
                        class="w-full bg-scheme-text/5 px-5 py-3 text-scheme-text/80"
                        data-shopify-xr
                        data-shopify-model3d-id="{{ first_3d_model.id }}"
                        data-shopify-title="{{ product.title }}"
                        data-shopify-xr-hidden
                      >
                        <span class="-mt-1 inline-block w-6 align-middle">
                          {%- render 'icon-model' -%}</span
                        ><span class="text-sm">
                          {{- 'products.media.view_in_your_space' | t -}}
                        </span>
                      </button>
                    </div>
                  {%- endif -%}
                  <div class="splide__arrows {% if enable_thumbnails_on_desktop %}splide__arrows--md-hidden{% endif %}">
                    <button class="splide__arrow splide__arrow--prev mr-1 p-1">
                      <span class="sr-only">
                        {{- 'sections.slideshow.previous_slide' | t -}}
                      </span>
                      <div class="h-8 w-8">
                        {% render 'icon-previous' %}
                      </div>
                    </button>
                    <button class="splide__arrow splide__arrow--next p-1">
                      <span class="sr-only">
                        {{- 'sections.slideshow.next_slide' | t -}}
                      </span>
                      <div class="h-8 w-8">
                        {% render 'icon-next' %}
                      </div>
                    </button>
                  </div>
                </div>
                {% unless request.design_mode %}
                  <script
                    src="{{ 'modules-slideshow.bundle.min.js' | asset_url }}"
                    type="module"
                  ></script>
                {% endunless %}
                {{
                  'modules-slideshow.bundle.css'
                  | asset_url
                  | stylesheet_tag
                }}
              </div>
            {% endif %}
          {% endif %}
        </div>
        <div
          class="pb-section md:col-span-item"
          style="--item-col-span: {{ product_content_col_span }};"
        >
          <div
            class="md:flex {{ section.settings.product_content_alignment }}"
          >
            <div
              class="{{ product_content_max_width }} grow"
              data-product-form-container
            >
              {% liquid
                for block in section.blocks
                  case block.type
                    when '@app'
                      render 'product-block-app', block: block

                    when 'liquid'
                      render 'product-block-liquid', block: block

                    when 'title'
                      render 'product-block-title', product: product, block: block

                    when 'price'
                      render 'product-form-component-price', product: product, block: block, class: 'my-3'

                    when 'variant_picker'
                      if block.settings.hide_option_labels
                        assign label_class = 'sr-only'
                      else
                        assign label_class = 'block font-secondary mb-2'
                      endif

                      render 'product-form-component-variant-picker', product: product, block: block, label_class: label_class, class: 'my-8'

                    when 'quantity_selector'
                      if block.settings.hide_label
                        assign label_class = 'sr-only'
                      else
                        assign label_class = 'block font-secondary my-2'
                      endif

                      render 'product-block-quantity', product_form_id: product_form_id, label_class: label_class, block: block

                    when 'buy_buttons'
                      render 'product-block-buy-buttons', product: product, product_form_id: product_form_id, label_class: label_class, current_variant: current_variant, block: block

                    when 'star_rating'
                      render 'product-block-star-rating', product: product, block: block

                    when 'text'
                      render 'product-block-text', block: block

                    when 'rich_text'
                      render 'product-block-rich-text', block: block

                    when 'description'
                      render 'product-block-description', product: product, block: block

                    when 'complementary'
                      render 'product-block-complementary', product: product, block: block, desktop_sizes_base: content_desktop_sizes_base

                    when 'supporting_links'
                      render 'product-block-supporting-links', block: block

                    when 'popup'
                      render 'product-block-popup', block: block

                    when 'collapsible_tabs'
                      render 'product-block-collapsible-tabs', block: block

                    when 'icon_list'
                      render 'product-block-icon-list', block: block

                    when 'horizontal_rule'
                      render 'product-block-horizontal-rule', block: block

                    when 'share'
                      render 'product-block-share', product: product, block: block

                    when 'tabs'
                      render 'product-block-tabs', block: block

                    when 'information'
                      render 'product-block-information', block: block
                  endcase
                endfor
              %}
            </div>
          </div>
        </div>
      </div>
    </div>
    {% for block in popup_blocks %}
      {% render 'product-popup-block-modal',
        section_id: section.id,
        block: block
      %}
    {% endfor %}
  </div>
</section>

{% if models.size %}
  <script type="application/json" id="ModelJson-{{ section.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script>
    window.ProductModel = {
      loadShopifyXR() {
        Shopify.loadFeatures([
          {
            name: 'shopify-xr',
            version: '1.0',
            onLoad: this.setupShopifyXR.bind(this),
          },
        ]);
      },

      setupShopifyXR(errors) {
        if (errors) return;

        if (!window.ShopifyXR) {
          document.addEventListener('shopify_xr_initialized', () =>
            this.setupShopifyXR()
          );
          return;
        }

        document.querySelectorAll('[id^="ModelJson-"]').forEach((modelJSON) => {
          window.ShopifyXR.addModels(JSON.parse(modelJSON.textContent));
          modelJSON.remove();
        });
        window.ShopifyXR.setupXRElements();
      },
    };

    window.addEventListener('DOMContentLoaded', () => {
      if (Shopify.designMode) {
        document
          .querySelectorAll('[data-shopify-xr-hidden]')
          .forEach((element) => element.classList.add('hidden'));
      }
      if (window.ProductModel) window.ProductModel.loadShopifyXR();
    });
  </script>
{% endif %}

{% if enable_image_zoom %}
  {% liquid
    assign modal_id = 'image-zoom-' | append: section.id
    assign zoom_section_url = product.url | append: '?section_id=main-product-zoom'
  %}
  <div
    x-data
    x-init="initTeleport($root)"
    x-cloak
  >
    <template data-should-teleport="#modal-slot">
      <template x-if="$store.modals.modal.contents === '{{ modal_id }}'">
        <div class="bg-scheme-background text-scheme-text">
          <button
            @click.prevent="$store.modals.close('{{ modal_id }}')"
            class="fixed right-10 ml-auto mt-5 block pt-4"
          >
            <span class="sr-only">
              {{- 'general.accessibility.close_modal' | t -}}
            </span>
            <span class="inline-block h-6 w-6 drop-shadow-[0.06rem_0.12rem_0_rgb(var(--color-scheme-background))]">
              {%- render 'icon-close' -%}
            </span>
          </button>
          <div
            id="{{ modal_id }}"
            data-modal-label="{{ product.title }}, {{ 'products.media.media' | t }}"
            x-html="
              $fetchedFragment(
                '{{ zoom_section_url }}',
                '.product-zoom'
              )
            "
          ></div>
        </div>
      </template>
    </template>
  </div>
  {% unless request.design_mode %}
    <script src="{{ 'zoom.js' | asset_url }}" type="module"></script>
  {% endunless %}
{% endif %}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "media_position_on_desktop",
      "label": "Media position on desktop",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "media_width_on_desktop",
      "label": "Media width on desktop",
      "options": [
        {
          "value": "6",
          "label": "1/2"
        },
        {
          "value": "7",
          "label": "3/5"
        },
        {
          "value": "8",
          "label": "2/3"
        },
        {
          "value": "9",
          "label": "3/4"
        }
      ],
      "default": "6"
    },
    {
      "type": "checkbox",
      "id": "enable_thumbnails_on_desktop",
      "label": "Enable thumbnails on desktop",
      "default": true
    },
    {
      "type": "select",
      "id": "thumbnails_width_on_desktop",
      "label": "Thumbnails width on desktop",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "grow",
          "label": "Grow"
        }
      ],
      "default": "small"
    },
    {
      "type": "header",
      "content": "Product content"
    },
    {
      "type": "select",
      "id": "product_content_width_on_desktop",
      "label": "Width on desktop",
      "options": [
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "narrow",
          "label": "Narrow"
        }
      ]
    },
    {
      "type": "select",
      "id": "product_content_alignment",
      "label": "Alignment on desktop",
      "options": [
        {
          "value": "md:justify-start",
          "label": "Left"
        },
        {
          "value": "md:justify-center",
          "label": "Center"
        },
        {
          "value": "md:justify-end",
          "label": "Right"
        }
      ],
      "default": "md:justify-start",
      "info": "Only applies if content width is set to “Narrow”"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable image zoom"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Enable video looping",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_video_autoplay",
      "label": "Enable video autoplay",
      "default": true,
      "info": "Video will be muted. Does not support YouTube or Vimeo."
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "text_size",
          "label": "Text size",
          "options": [
            {
              "value": "text-heading-standard",
              "label": "Standard"
            },
            {
              "value": "text-heading-feature",
              "label": "Feature"
            }
          ],
          "default": "text-heading-standard"
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",

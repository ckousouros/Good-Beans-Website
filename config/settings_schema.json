      {
        "type": "color_scheme",
        "id": "modal_color_scheme",
        "label": "Color scheme",
        "default": "scheme2"
      },
      {
        "type": "header",
        "content": "Transitions"
      },
      {
        "type": "paragraph",
        "content": "Enable a transition animation between sections with different color schemes."
      },
      {
        "type": "checkbox",
        "id": "enable_section_color_transitions",
        "label": "Enable section color transitions",
        "default": false
      }
    ]
  },

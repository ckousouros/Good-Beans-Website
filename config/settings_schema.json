          {
            "type": "color",
            "id": "accent",
            "label": "Accent",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "accent_contrast",
            "label": "Accent contrast",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary",
            "label": "Secondary",
            "default": "#121212"
          }

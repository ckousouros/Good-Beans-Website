        "role": {
          "background": "background",
          "text": "text",
          "primary_button": "accent",
          "on_primary_button": "accent_contrast",
          "primary_button_border": "accent",
          "secondary_button": "text",
          "on_secondary_button": "background",
          "secondary_button_border": "text",
          "icons": "text",
          "links": "text"

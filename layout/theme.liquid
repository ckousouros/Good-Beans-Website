<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {%- unless settings.type_header_font.system?
      and settings.type_body_font.system?
    -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>{{ page_title }}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    {% liquid
      render 'meta-tags'
      render 'js-bridge'
    %}

    <script src="{{ 'utils.js' | asset_url }}" defer></script>
    <script
      src="{{ 'polyfills-inert.bundle.min.js' | asset_url }}"
      type="module"
    ></script>
    <script
      src="{{ 'global.bundle.min.js' | asset_url }}"
      type="module"
    ></script>
    {% if settings.quantity_style == 'dropdown' %}
      <script
        src="{{ 'quantity-dropdown.js' | asset_url }}"
        type="module"
      ></script>
    {% endif %}
    <script
      src="{{ 'quantity-stepper.js' | asset_url }}"
      type="module"
    ></script>
    {% if template == 'cart' or settings.cart_type == 'drawer' %}
      <script src="{{ 'cart-items.js' | asset_url }}" type="module"></script>
      <script src="{{ 'cart-footer.js' | asset_url }}" type="module"></script>
      {% if settings.cart_notes_enable %}
        <script src="{{ 'cart-note.js' | asset_url }}" type="module"></script>
      {% endif %}
    {% endif %}
    {% if request.design_mode %}
      {% comment %} If theme editor, load all modules {% endcomment %}
      <script src="{{ 'cart-count.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'vendor-product.bundle.min.js' | asset_url }}"
        type="module"
      ></script>
      <script src="{{ 'product.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'video.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'youtube-embed.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'vimeo-embed.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'html-video.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'scrolling-items.js' | asset_url }}"
        type="module"
      ></script>
      <script src="{{ 'product-model.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'sections-test-section.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'modules-slideshow.bundle.min.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'theme-editor-support.js' | asset_url }}"
        type="module"
      ></script>
      <script src="{{ 'faq.js' | asset_url }}" type="module"></script>
      <script src="{{ 'rte.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'sections-age-check.bundle.min.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'sections-promo-popup.bundle.min.js' | asset_url }}"
        type="module"
      ></script>
      <script
        src="{{ 'cookies-banner.js' | asset_url }}"
        type="module"
      ></script>
      <script src="{{ 'zoom-host.js' | asset_url }}" type="module"></script>
      <script src="{{ 'zoom.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'cascade-animations.js' | asset_url }}"
        type="module"
      ></script>
      <script src="{{ 'logo-list.js' | asset_url }}" type="module"></script>
      <script
        src="{{ 'gift-card-recipient.js' | asset_url }}"
        type="module"
      ></script>

      {% if settings.predictive_search_enabled %}
        <script
          src="{{ 'predictive-search.js' | asset_url }}"
          type="module"
        ></script>
      {% endif %}
    {% endif %}

    <script src="{{ 'nav-store.js' | asset_url }}" type="module"></script>

    {{ 'base.bundle.css' | asset_url | stylesheet_tag }}
    {{ 'global.css' | asset_url | stylesheet_tag }}
    {{ 'modules-rte.bundle.css' | asset_url | stylesheet_tag }}
    <link rel="stylesheet" href="{{ 'custom.css' | asset_url }}">

    {% if template contains 'customers' %}
      {% comment %}theme-check-disable ParserBlockingScript{% endcomment %}
      {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
      {{ 'customer_area.js' | shopify_asset_url | script_tag }}
      {% comment %}theme-check-enable ParserBlockingScript{% endcomment %}
    {% endif %}

    {% render 'css-bridge' %}

    <script>
      function onYouTubeIframeAPIReady() {
        document.body.dispatchEvent(new CustomEvent('youtubeiframeapiready'));
      }
    </script>
    <script src="{{ 'enhancements.js' | asset_url }}" defer></script>
    <!-- Meta Pixel Code -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '1577819369984836');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=1577819369984836&ev=PageView&noscript=1"
/></noscript>
<!-- End Meta Pixel Code -->
  </head>

  <body class="theme-ctas-are-{{ settings.cta_style }}s theme-buttons-style-{{ settings.button_style }} {% if settings.show_slideshow_pagination %} show-slideshow-pagination {% endif %}">
    <a class="skip-link" href="#MainContent">
      {{- 'general.accessibility.skip_to_content' | t -}}
    </a>

    {% liquid
      sections 'header-group'
      render 'header-group-support'
    %}

    <div id="MainContent">
      {% if request.page_type == 'policy' %}
        <section data-color-scheme="{{ settings.color_schemes | first }}">
      {% endif %}
      {{ content_for_layout }}
      {% if request.page_type == 'policy' %}
        </section>
      {% endif %}
    </div>

    {% liquid
      sections 'footer-group'
      sections 'overlay-group'
      render 'js-templates'
    %}

    <div
      id="screenreader-announce"
      class="sr-only"
      aria-live="polite"
      role="status"
    ></div>

    <ul hidden>
      <li id="a11y-refresh-page-message">
        {{ 'general.accessibility.refresh_page' | t }}
      </li>
      <li id="a11y-selection-message">
        {{ 'general.accessibility.selection_help' | t }}
      </li>
    </ul>

    {% comment %} Modal containers {% endcomment %}
    {% liquid
      render 'left-drawer'
      render 'right-drawer'
      render 'modal'
      render 'promo'
      render 'popup'
    %}
    <script src="{{ 'modals.js' | asset_url }}" type="module"></script>

    {% comment %} Modal contents {% endcomment %}
    {% if settings.cart_type == 'drawer' and template.name != 'cart' %}
      {% render 'drawer-cart' %}
    {% endif %}
    <script
      src="{{ 'alpine.bundle.min.js' | asset_url }}"
      type="module"
    ></script>
    <script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.querySelector('[data-section-id="template--26651908931886__collection_list_M6Y4L3"]');
    if (!section) return;

    section.querySelectorAll('[data-scale-reveal]').forEach(function(el) {
      el.removeAttribute('data-scale-reveal');
    });
    section.querySelectorAll('[data-zoom-on-hover]').forEach(function(el) {
      el.removeAttribute('data-zoom-on-hover');
    });

    var inner = section.querySelector('.relative > div');
    if (inner) {
      inner.setAttribute('style', 'display:flex !important; flex-wrap:nowrap !important; gap:1rem; align-items:stretch;');
    }

    section.querySelectorAll('[data-media-item]').forEach(function(el) {
      el.setAttribute('style', 'flex:1 1 0; min-width:0; width:auto !important; position:static !important; top:auto !important; left:auto !important;');
    });
  });
</script>

  </body>
</html>
